// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model EventRequest {
  id        String   @id @default(cuid())
  rawInput  String // "A 10-person leadership retreat..."
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proposal VenueProposal? // 1-to-1: one request = one proposal

  @@map("event_requests")
}

model VenueProposal {
  id            String   @id @default(cuid())
  venueName     String
  location      String
  estimatedCost String // e.g. "$3,200 - $3,800"
  whyItFits     String   @db.Text // AI justification paragraph
  amenities     String[] // bonus: array of amenities
  createdAt     DateTime @default(now())

  eventRequestId String       @unique
  eventRequest   EventRequest @relation(fields: [eventRequestId], references: [id], onDelete: Cascade)

  @@map("venue_proposals")
}
